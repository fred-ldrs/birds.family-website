---
/**
 * /src/pages/[lang]/bebebirdie.astro
 * Generated routes: /en/bebebirdie/, /de/bebebirdie/, /fr/bebebirdie/
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLanguagePaths } from '../../utils/i18n.js';

import en from '../../locales/en.json';
import de from '../../locales/de.json';
import fr from '../../locales/fr.json';

const locales = { en, de, fr };

export function getStaticPaths() {
  return getLanguagePaths();
}

const { lang } = Astro.params as { lang: 'en' | 'de' | 'fr' };
const t = locales[lang];
const s = t.bebebirdie;
---
<BaseLayout lang={lang} t={t} pageMeta={s.meta} currentPath="bebebirdie/">

  <!-- Hero -->
  <header class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <h1>{s.headline}</h1>
          <p class="subtitle">{s.subtitle}</p>
          <div class="cta-primary">
            <a
              href="https://play.google.com/store/apps/details?id=app.lueders.bebebirdie"
              class="google-play-button"
              target="_blank"
              rel="noopener"
            >
              <img src="/images/google-play-badge.png" alt={s.googlePlay} class="play-badge" />
            </a>
          </div>
        </div>
        <div class="hero-image">
          <img src="/images/Screenshot_1774263593.png" alt="BébéBirdie App Screenshot" class="app-preview" />
        </div>
      </div>
    </div>
  </header>

  <!-- Description -->
  <section class="description">
    <div class="container">
      <div class="description-content">
        <p class="lead">{s.lead}</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <div class="features-grid">

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 18V5l12-2v13" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="6" cy="18" r="3" stroke="#7EC4A8" stroke-width="2"/>
              <circle cx="18" cy="16" r="3" stroke="#7EC4A8" stroke-width="2"/>
            </svg>
          </div>
          <h3>{s.features.f1.title}</h3>
          <p>{s.features.f1.text}</p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <polyline points="17 1 21 5 17 9" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M3 11V9a4 4 0 0 1 4-4h14" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
              <polyline points="7 23 3 19 7 15" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M21 13v2a4 4 0 0 1-4 4H3" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>{s.features.f2.title}</h3>
          <p>{s.features.f2.text}</p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>{s.features.f3.title}</h3>
          <p>{s.features.f3.text}</p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 15V17M6 21H18C19.1046 21 20 20.1046 20 19V13C20 11.8954 19.1046 11 18 11H6C4.89543 11 4 11.8954 4 13V19C4 20.1046 4.89543 21 6 21Z" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
              <path d="M8 11V7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7V11" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>{s.features.f4.title}</h3>
          <p>{s.features.f4.text}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Bird illustration -->
  <section class="bird-section">
    <div class="container">
      <div class="bird-illustration">
        <img src="/images/BebeBirdie_clear_cut.png" alt="BébéBirdie" class="bird-img" />
      </div>
    </div>
  </section>

</BaseLayout>
