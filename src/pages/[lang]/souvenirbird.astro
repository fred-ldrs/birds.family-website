---
/**
 * /src/pages/[lang]/souvenirbird.astro
 * Generated routes: /en/souvenirbird/, /de/souvenirbird/, /fr/souvenirbird/
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLanguagePaths } from '../../utils/i18n.js';

import en from '../../locales/en.json';
import de from '../../locales/de.json';
import fr from '../../locales/fr.json';

const locales = { en, de, fr };

export function getStaticPaths() {
  return getLanguagePaths();
}

const { lang } = Astro.params as { lang: 'en' | 'de' | 'fr' };
const t = locales[lang];
const s = t.souvenirbird;
---
<BaseLayout lang={lang} t={t} pageMeta={s.meta} currentPath="souvenirbird/">

  <!-- Hero -->
  <header class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <h1>{s.headline}</h1>
          <p class="subtitle">{s.subtitle}</p>
          <div class="cta-primary">
            <a
              href="https://play.google.com/store/apps/details?id=app.lueders.souvenirbird"
              class="google-play-button"
              target="_blank"
              rel="noopener"
            >
              <img src="/images/google-play-badge.png" alt={s.googlePlay} class="play-badge" />
            </a>
          </div>
        </div>
        <div class="hero-image">
          <img src="/images/Screenshot_1772977403.png" alt="SouvenirBird App Screenshot" class="app-preview" />
        </div>
      </div>
    </div>
  </header>

  <!-- Description -->
  <section class="description">
    <div class="container">
      <div class="description-content">
        <p class="lead">{s.lead}</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <div class="features-grid">

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 8V12L15 15" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
              <circle cx="12" cy="12" r="9" stroke="#7EC4A8" stroke-width="2"/>
            </svg>
          </div>
          <h3>{s.features.f1.title}</h3>
          <p>{s.features.f1.text}</p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 15V17M6 21H18C19.1046 21 20 20.1046 20 19V13C20 11.8954 19.1046 11 18 11H6C4.89543 11 4 11.8954 4 13V19C4 20.1046 4.89543 21 6 21Z" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
              <path d="M8 11V7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7V11" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>{s.features.f2.title}</h3>
          <p>{s.features.f2.text}</p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>{s.features.f3.title}</h3>
          <p>{s.features.f3.text}</p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 11L12 14L22 4" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M21 12V19C21 20.1046 20.1046 21 19 21H5C3.89543 21 3 20.1046 3 19V5C3.89543 5 3 5.89543 3 5V5C3 3.89543 3.89543 3 5 3H16" stroke="#7EC4A8" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>{s.features.f4.title}</h3>
          <p>{s.features.f4.text}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Bird illustration -->
  <section class="bird-section">
    <div class="container">
      <div class="bird-illustration">
        <img src="/images/SouvenirBird_clear_cut.png" alt="SouvenirBird" class="bird-img" />
      </div>
    </div>
  </section>

</BaseLayout>
