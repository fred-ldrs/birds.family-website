<html>
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content="0; url=/en/" />
  <link rel="canonical" href="/en/" />
</head>
<body>
  <a href="/en/">Redirecting to /en/…</a>
</body>
</html>
